```components/BentoCell.tsx
import React from 'react'
import { motion } from 'framer-motion'
interface BentoCellProps {
  children: ReactNode
  className?: string
  delay?: number
  span?: 'full' | 'half' | 'third' | 'two-thirds' | 'quarter'
  height?: 'auto' | 'tall' | 'short'
  interactive?: boolean
}
export function BentoCell({
  children,
  className = '',
  delay = 0,
  span = 'third',
  height = 'auto',
  interactive = false,
}: BentoCellProps) {
  const spanClasses = {
    full: 'col-span-12',
    half: 'col-span-12 md:col-span-6',
    third: 'col-span-12 sm:col-span-6 lg:col-span-4',
    'two-thirds': 'col-span-12 lg:col-span-8',
    quarter: 'col-span-6 lg:col-span-3',
  }
  const heightClasses = {
    auto: '',
    tall: 'min-h-[320px] md:min-h-[400px]',
    short: 'min-h-[160px] md:min-h-[200px]',
  }
  return (
    <motion.div
      initial={{
        opacity: 0,
        y: 20,
        scale: 0.98,
      }}
      animate={{
        opacity: 1,
        y: 0,
        scale: 1,
      }}
      transition={{
        duration: 0.5,
        delay,
        ease: [0.25, 0.1, 0.25, 1],
      }}
      className={`
        ${spanClasses[span]}
        ${heightClasses[height]}
        bg-white
        border border-[#E5E7EB]
        rounded-[16px]
        overflow-hidden
        ${interactive ? 'cursor-pointer transition-shadow duration-300 hover:shadow-lg' : ''}
        ${className}
      `}
    >
      {children}
    </motion.div>
  )
}

